# Firebase Web SDK config (from Firebase Console > Project Settings > General > Your apps)
# These are public client identifiers, not secrets — access is controlled by Firestore
# security rules, not by keeping these values hidden.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloudinary (used for photo uploads instead of Firebase Storage, which now
# requires a paid Blaze plan). From cloudinary.com > Dashboard, plus an
# unsigned upload preset you create under Settings > Upload > Upload presets.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
