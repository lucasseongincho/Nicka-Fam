# Firebase Web SDK config (from Firebase Console > Project Settings > General > Your apps)
# These are public client identifiers, not secrets — access is controlled by Firestore
# security rules, not by keeping these values hidden.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloudinary (used for photo uploads instead of Firebase Storage, which now
# requires a paid Blaze plan). From cloudinary.com > Dashboard, plus an
# unsigned upload preset you create under Settings > Upload > Upload presets.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Push notifications (FCM). This is a public key (safe to ship to the
# client), not a secret -- from Firebase Console > Project Settings >
# Cloud Messaging > Web configuration > "Web Push certificates" > generate
# a key pair. Without this set, the notification-permission button still
# works, it just can't mint a device token yet.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Server-only service account for *sending* pushes from app/api/notify
# (no Firebase Cloud Functions here -- this project intentionally stays
# off the paid Blaze plan, so triggers are plain Vercel API routes called
# right after each write succeeds). From Firebase Console > Project
# Settings > Service Accounts > "Generate new private key", which
# downloads a JSON file containing project_id/client_email/private_key.
# Set these in Vercel's own dashboard for production -- never commit the
# actual values, and never paste them into chat/AI tools.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
